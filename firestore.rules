// =============================================
//  ZENDA — Firestore Security Rules
// =============================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helper functions (Now Null-Safe!) ----
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      // Safely check if the user document exists before trying to read it
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        : null;
    }

    function getUserRole() {
      let data = getUserData();
      return data != null ? data.role : 'none';
    }

    function getCompanyId() {
      let data = getUserData();
      return data != null ? data.companyId : 'none';
    }

    // ---- COMPANIES ----
    match /companies/{companyId} {
      allow read: if isSignedIn() && getCompanyId() == companyId;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (getUserRole() == 'owner' || resource.data.ownerId == request.auth.uid);
      allow delete: if false;
    }

    // ---- USERS ----
    match /users/{userId} {
      allow read: if isSignedIn();
      
      // Allow users to create their own profile OR allow owners to create staff
      allow create: if isSignedIn() && (request.auth.uid == userId || getUserRole() == 'owner');
      
      // Allow users to update themselves OR allow owners to update staff
      allow update: if isSignedIn() && (
        request.auth.uid == userId ||
        (getUserRole() == 'owner' && getCompanyId() == resource.data.companyId)
      );
      
      // Allow owners to delete staff
      allow delete: if isSignedIn() && getUserRole() == 'owner';
    }

    // ---- TASKS ----
    match /tasks/{taskId} {
      allow read: if isSignedIn() && getCompanyId() == resource.data.companyId;
      allow create: if isSignedIn() && (getUserRole() == 'owner' || getUserRole() == 'manager');
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.assignedTo ||
        request.auth.uid == resource.data.assignedBy
      );
      allow delete: if isSignedIn() && request.auth.uid == resource.data.assignedBy;
    }

    // ---- NOTIFICATIONS ----
    match /users/{userId}/notifications/{notifId} {
      allow read, update, delete: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn();
    }

    // ---- OTPs ----
    match /otps/{emailKey} {
      allow read, write: if true;
    }

    // ---- INSTALLED APPS ----
    match /installedApps/{userId} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || getUserRole() == 'owner');
    }

    // ---- APP DATA ----
    match /appData/{userId}/apps/{appId} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || getUserRole() == 'owner');
    }
  }
}
